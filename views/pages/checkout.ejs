<div id="app" class="max-w-[1100px] mx-auto px-6 md:px-14 py-12">
  <h1 class="font-display text-4xl text-cream mb-10">結帳</h1>

  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border border-kaki border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else class="flex flex-col lg:flex-row gap-10 lg:gap-16">
    <!-- Left: Form -->
    <div class="lg:w-2/3">
      <h2 class="cap text-[12px] text-kaki mb-8">收件資訊 / SHIPPING</h2>
      <div class="space-y-8">
        <div>
          <label class="field-label">收件人姓名</label>
          <input
            v-model="form.recipientName"
            type="text"
            placeholder="請輸入收件人姓名"
            class="field-input"
            :class="{ 'is-error': errors.recipientName }"
          />
          <p v-if="errors.recipientName" class="text-[#B8553E] text-xs mt-2">{{ errors.recipientName }}</p>
        </div>
        <div>
          <label class="field-label">Email</label>
          <input
            v-model="form.recipientEmail"
            type="email"
            placeholder="請輸入 Email"
            class="field-input"
            :class="{ 'is-error': errors.recipientEmail }"
          />
          <p v-if="errors.recipientEmail" class="text-[#B8553E] text-xs mt-2">{{ errors.recipientEmail }}</p>
        </div>
        <div>
          <label class="field-label">收件地址</label>
          <input
            v-model="form.recipientAddress"
            type="text"
            placeholder="請輸入收件地址"
            class="field-input"
            :class="{ 'is-error': errors.recipientAddress }"
          />
          <p v-if="errors.recipientAddress" class="text-[#B8553E] text-xs mt-2">{{ errors.recipientAddress }}</p>
        </div>
      </div>
    </div>

    <!-- Right: Summary -->
    <div class="lg:w-1/3">
      <div class="bg-raised p-8 sticky top-24">
        <h2 class="cap text-[12px] text-kaki mb-6">訂單摘要 / SUMMARY</h2>
        <div class="space-y-3 mb-6">
          <div v-for="item in cartItems" :key="item.id" class="flex justify-between text-sm">
            <span class="text-mist">{{ item.product.name }} x {{ item.quantity }}</span>
            <span class="text-cream">NT$ {{ (item.product.price * item.quantity).toLocaleString() }}</span>
          </div>
        </div>
        <div class="border-t border-hairline pt-6 space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-mist">商品小計</span>
            <span class="text-cream">NT$ {{ cartTotal.toLocaleString() }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-mist">運費</span>
            <span class="text-cream">{{ cartTotal >= 500 ? '免運' : 'NT$ 150' }}</span>
          </div>
        </div>
        <div class="border-t border-hairline pt-6 mt-6 flex justify-between items-center mb-8">
          <span class="cap text-[12px] text-mist">總計</span>
          <span class="font-serif text-2xl text-kaki">
            NT$ {{ (cartTotal + (cartTotal >= 500 ? 0 : 150)).toLocaleString() }}
          </span>
        </div>
        <button
          @click="submitOrder"
          :disabled="submitting"
          class="btn-primary w-full"
        >
          {{ submitting ? '處理中...' : '確認送出訂單' }}
        </button>
        <p class="cap text-[10px] text-ash text-center mt-6">SECURE PAYMENT VIA ECPAY 綠界金流</p>
      </div>
    </div>
  </div>
</div>
