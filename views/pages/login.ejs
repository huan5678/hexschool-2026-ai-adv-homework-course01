<div id="app">
  <div class="min-h-screen flex">
    <!-- 左：暗調植物影像欄 -->
    <div class="hidden md:block md:w-1/2 relative">
      <img
        src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?auto=format&fit=crop&w=1200&q=80"
        alt="花卉"
        class="absolute inset-0 w-full h-full object-cover opacity-70"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/60 to-ink/40"></div>
      <div class="absolute bottom-12 left-12 right-12">
        <p class="eyebrow mb-3">&mdash; 一期一會</p>
        <p class="font-display text-cream text-4xl tracking-[0.15em]">花漾生活</p>
      </div>
    </div>

    <!-- 右：登入欄 -->
    <div class="w-full md:w-1/2 flex items-center justify-center px-6 py-16 bg-ink">
      <div class="w-full max-w-[400px]">
        <h1 class="font-display text-2xl text-kaki mb-2">花漾生活</h1>
        <p class="cap text-[11px] text-ash mb-10">會員登入 / SIGN IN</p>

        <!-- Tabs（底線式） -->
        <div class="flex gap-8 mb-10">
          <button
            @click="activeTab = 'login'; errors = {}"
            class="pb-3 text-sm transition-colors"
            :class="activeTab === 'login' ? 'text-cream border-b-2 border-kaki' : 'text-ash border-b border-hairline'"
          >
            登入
          </button>
          <button
            @click="activeTab = 'register'; errors = {}"
            class="pb-3 text-sm transition-colors"
            :class="activeTab === 'register' ? 'text-cream border-b-2 border-kaki' : 'text-ash border-b border-hairline'"
          >
            註冊
          </button>
        </div>

        <!-- Login Form -->
        <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="space-y-7">
          <div>
            <label class="field-label">Email</label>
            <input
              v-model="loginForm.email"
              type="email"
              placeholder="請輸入 Email"
              class="field-input"
              :class="{ 'is-error': errors.email }"
            />
            <p v-if="errors.email" class="text-[#B8553E] text-xs mt-2">{{ errors.email }}</p>
          </div>

          <div>
            <label class="field-label">密碼</label>
            <input
              v-model="loginForm.password"
              type="password"
              placeholder="請輸入密碼"
              class="field-input"
              :class="{ 'is-error': errors.password }"
            />
            <p v-if="errors.password" class="text-[#B8553E] text-xs mt-2">{{ errors.password }}</p>
          </div>

          <button type="submit" :disabled="submitting" class="btn-primary w-full">
            {{ submitting ? '登入中...' : '登入' }}
          </button>
        </form>

        <!-- Register Form -->
        <form v-else @submit.prevent="handleRegister" class="space-y-7">
          <div>
            <label class="field-label">姓名</label>
            <input
              v-model="registerForm.name"
              type="text"
              placeholder="請輸入姓名"
              class="field-input"
              :class="{ 'is-error': errors.name }"
            />
            <p v-if="errors.name" class="text-[#B8553E] text-xs mt-2">{{ errors.name }}</p>
          </div>

          <div>
            <label class="field-label">Email</label>
            <input
              v-model="registerForm.email"
              type="email"
              placeholder="請輸入 Email"
              class="field-input"
              :class="{ 'is-error': errors.email }"
            />
            <p v-if="errors.email" class="text-[#B8553E] text-xs mt-2">{{ errors.email }}</p>
          </div>

          <div>
            <label class="field-label">密碼</label>
            <input
              v-model="registerForm.password"
              type="password"
              placeholder="至少 6 個字元"
              class="field-input"
              :class="{ 'is-error': errors.password }"
            />
            <p v-if="errors.password" class="text-[#B8553E] text-xs mt-2">{{ errors.password }}</p>
          </div>

          <button type="submit" :disabled="submitting" class="btn-primary w-full">
            {{ submitting ? '註冊中...' : '註冊' }}
          </button>
        </form>

        <!-- 底部切換提示 -->
        <p class="cap text-[11px] text-mist mt-10">
          <template v-if="activeTab === 'login'">尚未加入會員？切換至「註冊」</template>
          <template v-else>已是會員？切換至「登入」</template>
        </p>
      </div>
    </div>
  </div>
</div>
