<div id="app">
  <h1 class="font-display text-4xl text-cream mb-10">我的訂單</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-2 border-kaki border-t-transparent animate-spin"></div>
  </div>

  <div v-else-if="orders.length === 0" class="text-center py-20">
    <p class="eyebrow mb-3">&mdash; 一期一會</p>
    <p class="text-mist mb-2">尚無訂單</p>
    <p class="text-ash text-sm mb-8">快去選購喜歡的花束吧！</p>
    <a href="/" class="btn-primary">去逛逛</a>
  </div>

  <div v-else class="space-y-4">
    <a
      v-for="order in orders"
      :key="order.id"
      :href="'/orders/' + order.id"
      class="block border border-hairline hover:border-mist transition-colors p-5"
    >
      <div class="flex items-center justify-between">
        <div>
          <p class="cap text-[12px] text-mist">{{ order.order_no }}</p>
          <p class="text-xs text-ash mt-1">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <div class="flex items-center gap-4">
          <span class="font-serif text-cream">NT$ {{ order.total_amount.toLocaleString() }}</span>
          <span
            class="inline-block border px-3 py-1 cap text-[11px]"
            :class="statusMap[order.status]?.cls || 'border-hairline text-mist'"
          >
            {{ statusMap[order.status]?.label || order.status }}
          </span>
          <span class="text-ash">&#8594;</span>
        </div>
      </div>
    </a>
  </div>
</div>
