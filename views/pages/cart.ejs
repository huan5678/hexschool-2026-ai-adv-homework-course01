<div id="app" class="max-w-[1100px] mx-auto px-6 md:px-14 py-12">
  <!-- Title -->
  <div class="flex items-baseline justify-between mb-10">
    <h1 class="font-display text-4xl text-cream">購物車</h1>
    <span v-if="items.length" class="cap text-[12px] text-ash">{{ items.length }} ITEMS</span>
  </div>

  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border border-kaki border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="items.length === 0" class="text-center py-24">
    <p class="text-mist mb-2">購物車是空的</p>
    <p class="text-ash text-sm mb-8">快去挑選喜歡的花束吧</p>
    <a href="/" class="btn-primary">去逛逛</a>
  </div>

  <template v-else>
    <!-- Free shipping banner -->
    <p v-if="total < 500" class="cap text-[12px] text-kaki mb-8">
      再買 NT$ {{ (500 - total).toLocaleString() }} 即可享免運費
    </p>
    <p v-else class="cap text-[12px] text-kaki mb-8">
      已達免運門檻
    </p>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">
      <!-- Cart Items -->
      <div class="flex-1">
        <div
          v-for="item in items"
          :key="item.id"
          class="flex items-center gap-5 py-5 border-b border-hairline"
        >
          <img
            :src="item.product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=100'"
            :alt="item.product.name"
            class="w-20 h-20 bg-raised object-cover flex-shrink-0"
          />
          <div class="flex-1 min-w-0">
            <h3 class="font-display text-cream truncate">{{ item.product.name }}</h3>
            <p class="cap text-[11px] text-mist mt-1">NT$ {{ item.product.price.toLocaleString() }}</p>
          </div>

          <!-- Quantity Controls -->
          <div class="stepper">
            <button
              @click="updateQuantity(item.id, item.quantity - 1)"
              :disabled="item.quantity <= 1"
            >
              &minus;
            </button>
            <span class="stepper-num">{{ item.quantity }}</span>
            <button
              @click="updateQuantity(item.id, item.quantity + 1)"
              :disabled="item.quantity >= item.product.stock"
            >
              +
            </button>
          </div>

          <p class="font-serif text-cream w-28 text-right">
            NT$ {{ (item.product.price * item.quantity).toLocaleString() }}
          </p>

          <button
            @click="confirmDelete(item.id)"
            class="text-ash hover:text-kaki transition-colors text-lg ml-1"
            aria-label="移除"
          >
            &times;
          </button>
        </div>
      </div>

      <!-- Summary -->
      <div class="lg:w-80 flex-shrink-0">
        <div class="bg-raised p-8">
          <h2 class="cap text-[12px] text-kaki mb-6">訂單摘要 / SUMMARY</h2>
          <div class="flex justify-between items-center mb-3 text-sm">
            <span class="text-mist">商品小計</span>
            <span class="text-cream">NT$ {{ total.toLocaleString() }}</span>
          </div>
          <div class="flex justify-between items-center mb-6 text-sm">
            <span class="text-mist">運費</span>
            <span class="text-cream">{{ total >= 500 ? '免運' : 'NT$ 150' }}</span>
          </div>
          <div class="border-t border-hairline pt-6 flex justify-between items-center mb-8">
            <span class="cap text-[12px] text-mist">總計</span>
            <span class="font-serif text-2xl text-kaki">
              NT$ {{ (total + (total >= 500 ? 0 : 150)).toLocaleString() }}
            </span>
          </div>
          <button @click="goCheckout" class="btn-primary w-full">
            前往結帳
          </button>
        </div>
      </div>
    </div>
  </template>

  <!-- Confirm Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" @click="confirmVisible = false"></div>
    <div class="relative bg-raised border border-hairline w-full max-w-sm mx-4 p-8 text-center">
      <h3 class="font-display text-xl text-cream mb-3">確認移除</h3>
      <p class="text-mist text-sm mb-8">確定要從購物車中移除這個商品嗎</p>
      <div class="flex gap-4 justify-center">
        <button @click="confirmVisible = false" class="btn-outline flex-1">取消</button>
        <button @click="handleDelete" class="btn-primary flex-1">確認移除</button>
      </div>
    </div>
  </div>
</div>
