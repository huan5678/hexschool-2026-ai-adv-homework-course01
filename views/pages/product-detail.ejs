<div id="app" data-product-id="<%= productId %>">
  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border border-kaki border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="notFound" class="text-center py-24 max-w-[1100px] mx-auto px-6 md:px-14">
    <p class="cap text-[11px] text-ash mb-4">404 &mdash; NOT FOUND</p>
    <h2 class="font-display text-3xl text-cream mb-4">找不到此商品</h2>
    <a href="/" class="btn-outline">回到首頁</a>
  </div>

  <div v-else-if="product" class="flex flex-col md:flex-row">
    <!-- Left: Image -->
    <div class="md:w-1/2 bg-raised">
      <img
        :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=600'"
        :alt="product.name"
        class="w-full h-[480px] md:h-[760px] lg:h-[860px] object-cover"
      />
    </div>

    <!-- Right: Info -->
    <div class="md:w-1/2 px-8 md:px-16 py-12 flex flex-col">
      <!-- Breadcrumb -->
      <p class="cap text-[11px] text-ash mb-8">所有花藝 / {{ product.name }}</p>

      <!-- Name -->
      <h1 class="font-display text-4xl md:text-5xl text-cream leading-tight mb-5">
        {{ product.name }}
      </h1>

      <!-- Price -->
      <p class="font-serif text-3xl text-kaki mb-6">NT$ {{ product.price.toLocaleString() }}</p>

      <!-- Stock -->
      <div class="flex items-center gap-2 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-kaki"></span>
        <span class="cap text-[12px] text-mist">現貨 &middot; 尚有 {{ product.stock }} 件</span>
      </div>

      <!-- Description -->
      <p class="text-mist leading-loose mb-8">{{ product.description }}</p>

      <!-- Divider -->
      <div class="border-t border-hairline pt-8"></div>

      <!-- Quantity Selector -->
      <div class="flex items-center gap-6 mb-8">
        <span class="cap text-[11px] text-mist">數量</span>
        <div class="stepper">
          <button @click="decrease">&minus;</button>
          <span class="stepper-num">{{ quantity }}</span>
          <button @click="increase">+</button>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <button
          @click="addToCart"
          :disabled="adding || product.stock <= 0"
          class="btn-primary flex-1"
        >
          {{ product.stock <= 0 ? '已售完' : '加入購物車' }}
        </button>
        <a href="/cart" class="btn-outline flex-1">直接結帳</a>
      </div>

      <!-- Purchase Notes -->
      <div class="border-t border-hairline pt-8">
        <h3 class="cap text-[11px] text-kaki mb-4">購買須知 / NOTES</h3>
        <ul class="text-ash text-sm leading-loose space-y-1">
          <li>— 花材依據季節供應，實際花束可能略有差異</li>
          <li>— 台北市區可享當日配送服務</li>
          <li>— 消費滿 NT$ 500 享免運優惠</li>
        </ul>
      </div>
    </div>
  </div>
</div>
