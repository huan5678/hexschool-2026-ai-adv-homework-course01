<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>">
  <h1 class="font-display text-4xl text-cream mb-10">訂單詳情</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-2 border-kaki border-t-transparent animate-spin"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div
      v-if="paymentResult && paymentMessages[paymentResult]"
      class="border p-4 mb-8 text-sm"
      :class="paymentMessages[paymentResult].cls"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <!-- Order Info -->
    <div class="bg-raised p-6 mb-8">
      <div class="flex items-start justify-between">
        <div>
          <p class="cap text-[12px] text-mist">{{ order.order_no }}</p>
          <p class="text-xs text-ash mt-2">建立日期：{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <span
          class="inline-block border px-3 py-1 cap text-[11px]"
          :class="statusMap[order.status]?.cls || 'border-hairline text-mist'"
        >
          {{ statusMap[order.status]?.label || order.status }}
        </span>
      </div>
    </div>

    <!-- Recipient Info -->
    <div class="border-t border-hairline pt-6 mb-8">
      <h2 class="cap text-[11px] text-kaki mb-4">收件資訊</h2>
      <div class="text-sm space-y-2 text-mist">
        <p>收件人：{{ order.recipient_name }}</p>
        <p>Email：{{ order.recipient_email }}</p>
        <p>地址：{{ order.recipient_address }}</p>
      </div>
    </div>

    <!-- Order Items -->
    <div class="border-t border-hairline pt-6 mb-8">
      <h2 class="cap text-[11px] text-kaki mb-4">商品明細</h2>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-hairline">
            <th class="text-left py-2 font-normal cap text-[11px] text-ash">商品名稱</th>
            <th class="text-right py-2 font-normal cap text-[11px] text-ash">單價</th>
            <th class="text-right py-2 font-normal cap text-[11px] text-ash">數量</th>
            <th class="text-right py-2 font-normal cap text-[11px] text-ash">小計</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="item in order.items" :key="item.id" class="border-b border-hairline">
            <td class="py-3 text-cream">{{ item.product_name }}</td>
            <td class="py-3 text-right text-mist">NT$ {{ item.product_price.toLocaleString() }}</td>
            <td class="py-3 text-right text-mist">{{ item.quantity }}</td>
            <td class="py-3 text-right text-cream">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="pt-4 text-right cap text-[11px] text-mist">總計</td>
            <td class="pt-4 text-right font-serif text-kaki text-lg">NT$ {{ order.total_amount.toLocaleString() }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment Buttons -->
    <div v-if="order.status === 'pending'" class="space-y-4">
      <!-- ECPay Payment (Primary) -->
      <div>
        <button
          @click="handleEcpayPay"
          :disabled="paying || checking"
          class="btn-primary w-full"
        >
          {{ paying ? '正在跳轉至 ECPay...' : '前往付款（ECPay 綠界）' }}
        </button>
      </div>

      <!-- Check Payment Status -->
      <div v-if="order.payment_trade_no">
        <button
          @click="checkPayment"
          :disabled="checking || paying"
          class="btn-outline w-full"
        >
          {{ checking ? '查詢中...' : '查詢付款狀態' }}
        </button>
      </div>

      <!-- Simulate Payment (Testing) -->
      <div class="pt-4 border-t border-hairline">
        <p class="cap text-[11px] text-ash mb-3">測試用模擬付款：</p>
        <div class="flex gap-3">
          <button
            @click="handlePaySuccess"
            :disabled="paying || checking"
            class="border border-hairline text-mist hover:border-mist px-6 py-2 cap text-[11px] transition-colors disabled:opacity-40"
          >
            模擬付款成功
          </button>
          <button
            @click="handlePayFail"
            :disabled="paying || checking"
            class="border border-hairline text-mist hover:border-mist px-6 py-2 cap text-[11px] transition-colors disabled:opacity-40"
          >
            模擬付款失敗
          </button>
        </div>
      </div>
    </div>
  </template>
</div>
