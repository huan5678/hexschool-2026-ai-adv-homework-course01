<div id="app">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="eyebrow mb-2">Admin</p>
      <h1 class="font-display text-3xl text-cream">商品管理</h1>
    </div>
    <button @click="openCreate" class="btn-primary">
      新增商品
    </button>
  </div>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-2 border-kaki border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else>
    <div class="bg-raised border border-hairline overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="cap text-[11px] text-ash border-b border-hairline">
            <th class="text-left px-4 py-3 font-normal">圖片</th>
            <th class="text-left px-4 py-3 font-normal">商品名稱</th>
            <th class="text-right px-4 py-3 font-normal">價格</th>
            <th class="text-right px-4 py-3 font-normal">庫存</th>
            <th class="text-right px-4 py-3 font-normal">操作</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="product in products" :key="product.id" class="border-b border-hairline">
            <td class="px-4 py-3">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=100'"
                :alt="product.name"
                class="w-12 h-12 object-cover border border-hairline"
              />
            </td>
            <td class="px-4 py-3 text-cream">{{ product.name }}</td>
            <td class="px-4 py-3 text-right font-serif text-mist">NT$ {{ product.price.toLocaleString() }}</td>
            <td class="px-4 py-3 text-right text-mist">{{ product.stock }}</td>
            <td class="px-4 py-3 text-right">
              <button
                @click="openEdit(product)"
                class="text-xs text-mist hover:text-cream transition-colors mr-4"
              >
                編輯
              </button>
              <button
                @click="confirmDeleteFn(product.id)"
                class="text-xs text-ash hover:text-[#B8553E] transition-colors"
              >
                刪除
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div v-if="pagination.totalPages > 1" class="flex justify-center gap-2 mt-8">
      <button
        v-for="p in pagination.totalPages"
        :key="p"
        @click="loadProducts(p)"
        class="w-10 h-10 cap text-[12px] border transition-colors"
        :class="p === pagination.page ? 'border-kaki text-kaki' : 'border-hairline text-mist hover:text-cream'"
      >
        {{ p }}
      </button>
    </div>
  </template>

  <!-- Product Modal -->
  <div v-if="modalVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" @click="modalVisible = false"></div>
    <div class="relative bg-raised border border-hairline w-full max-w-lg mx-4 p-8">
      <h3 class="font-display text-xl text-cream mb-6">
        {{ editingProduct ? '編輯商品' : '新增商品' }}
      </h3>
      <form @submit.prevent="handleSave" class="space-y-5">
        <div>
          <label class="field-label">商品名稱 *</label>
          <input v-model="form.name" type="text" class="field-input" />
        </div>
        <div>
          <label class="field-label">商品描述</label>
          <textarea v-model="form.description" rows="3" class="field-input"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="field-label">價格 *</label>
            <input v-model.number="form.price" type="number" min="1" class="field-input" />
          </div>
          <div>
            <label class="field-label">庫存 *</label>
            <input v-model.number="form.stock" type="number" min="0" class="field-input" />
          </div>
        </div>
        <div>
          <label class="field-label">圖片 URL</label>
          <input v-model="form.image_url" type="text" class="field-input" />
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" @click="modalVisible = false" class="btn-outline">取消</button>
          <button type="submit" :disabled="saving" class="btn-primary">
            {{ saving ? '儲存中...' : '儲存' }}
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Confirm Delete Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" @click="confirmVisible = false"></div>
    <div class="relative bg-raised border border-hairline w-full max-w-sm mx-4 p-8 text-center">
      <h3 class="font-display text-xl text-cream mb-3">確認刪除</h3>
      <p class="text-mist text-sm mb-6">確定要刪除這個商品嗎？此操作無法復原。</p>
      <div class="flex gap-3 justify-center">
        <button @click="confirmVisible = false" class="btn-outline">取消</button>
        <button @click="handleDelete" class="btn-primary">確認刪除</button>
      </div>
    </div>
  </div>
</div>
