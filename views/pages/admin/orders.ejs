<div id="app">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="eyebrow mb-2">Admin</p>
      <h1 class="font-display text-3xl text-cream">訂單管理</h1>
    </div>
    <div class="flex items-center gap-2">
      <button
        v-for="opt in statusOptions"
        :key="opt.value"
        @click="statusFilter = opt.value"
        class="cap text-[12px] px-4 py-2 border transition-colors"
        :class="statusFilter === opt.value ? 'text-kaki border-kaki' : 'text-mist border-hairline hover:text-cream'"
      >
        {{ opt.label }}
      </button>
    </div>
  </div>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-2 border-kaki border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else>
    <div class="bg-raised border border-hairline overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="cap text-[11px] text-ash border-b border-hairline">
            <th class="text-left px-4 py-3 font-normal">訂單編號</th>
            <th class="text-left px-4 py-3 font-normal">買家</th>
            <th class="text-right px-4 py-3 font-normal">金額</th>
            <th class="text-center px-4 py-3 font-normal">狀態</th>
            <th class="text-right px-4 py-3 font-normal">日期</th>
          </tr>
        </thead>
        <tbody>
          <tr
            v-for="order in orders"
            :key="order.id"
            class="border-b border-hairline hover:bg-ink cursor-pointer transition-colors"
            @click="viewDetail(order.id)"
          >
            <td class="px-4 py-3 text-cream">{{ order.order_no }}</td>
            <td class="px-4 py-3 text-mist">{{ order.recipient_name }}</td>
            <td class="px-4 py-3 text-right font-serif text-cream">NT$ {{ order.total_amount.toLocaleString() }}</td>
            <td class="px-4 py-3 text-center">
              <span
                class="cap text-[11px] px-2.5 py-1 border"
                :class="statusMap[order.status]?.cls || 'text-mist border-hairline'"
              >
                {{ statusMap[order.status]?.label || order.status }}
              </span>
            </td>
            <td class="px-4 py-3 text-right text-ash">
              {{ new Date(order.created_at).toLocaleDateString('zh-TW') }}
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div v-if="pagination.totalPages > 1" class="flex justify-center gap-2 mt-8">
      <button
        v-for="p in pagination.totalPages"
        :key="p"
        @click="loadOrders(p)"
        class="w-10 h-10 cap text-[12px] border transition-colors"
        :class="p === pagination.page ? 'border-kaki text-kaki' : 'border-hairline text-mist hover:text-cream'"
      >
        {{ p }}
      </button>
    </div>
  </template>

  <!-- Order Detail Modal -->
  <div v-if="detailVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" @click="detailVisible = false"></div>
    <div class="relative bg-raised border border-hairline w-full max-w-2xl mx-4 p-8 max-h-[80vh] overflow-y-auto">
      <div v-if="detailLoading" class="flex justify-center py-8">
        <div class="w-8 h-8 border-2 border-kaki border-t-transparent rounded-full animate-spin"></div>
      </div>
      <template v-else-if="detailOrder">
        <div class="flex items-start justify-between mb-6">
          <h3 class="font-display text-xl text-cream">訂單詳情</h3>
          <button @click="detailVisible = false" class="text-ash hover:text-cream text-lg transition-colors">&times;</button>
        </div>

        <div class="space-y-6 text-sm">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="cap text-[11px] text-ash mb-1">訂單編號</p>
              <p class="text-cream">{{ detailOrder.order_no }}</p>
            </div>
            <div>
              <p class="cap text-[11px] text-ash mb-1">狀態</p>
              <span
                class="cap text-[11px] px-2.5 py-1 border"
                :class="statusMap[detailOrder.status]?.cls || 'text-mist border-hairline'"
              >
                {{ statusMap[detailOrder.status]?.label || detailOrder.status }}
              </span>
            </div>
            <div>
              <p class="cap text-[11px] text-ash mb-1">買家</p>
              <p class="text-mist">{{ detailOrder.user?.name }} ({{ detailOrder.user?.email }})</p>
            </div>
            <div>
              <p class="cap text-[11px] text-ash mb-1">日期</p>
              <p class="text-cream">{{ new Date(detailOrder.created_at).toLocaleDateString('zh-TW') }}</p>
            </div>
          </div>

          <div class="border-t border-hairline pt-6">
            <p class="cap text-[11px] text-ash mb-2">收件資訊</p>
            <p class="text-cream">{{ detailOrder.recipient_name }}</p>
            <p class="text-mist">{{ detailOrder.recipient_email }}</p>
            <p class="text-mist">{{ detailOrder.recipient_address }}</p>
          </div>

          <div class="border-t border-hairline pt-6">
            <p class="cap text-[11px] text-ash mb-2">商品明細</p>
            <table class="w-full">
              <thead>
                <tr class="cap text-[11px] text-ash border-b border-hairline">
                  <th class="text-left py-2 font-normal">商品名稱</th>
                  <th class="text-right py-2 font-normal">單價</th>
                  <th class="text-right py-2 font-normal">數量</th>
                  <th class="text-right py-2 font-normal">小計</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="item in detailOrder.items" :key="item.id" class="border-b border-hairline">
                  <td class="py-2 text-cream">{{ item.product_name }}</td>
                  <td class="py-2 text-right font-serif text-mist">NT$ {{ item.product_price.toLocaleString() }}</td>
                  <td class="py-2 text-right text-mist">{{ item.quantity }}</td>
                  <td class="py-2 text-right font-serif text-cream">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
                </tr>
              </tbody>
            </table>
            <div class="flex justify-end mt-3 pt-3 border-t border-hairline">
              <span class="font-serif text-kaki text-lg">總計 NT$ {{ detailOrder.total_amount.toLocaleString() }}</span>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>
</div>
