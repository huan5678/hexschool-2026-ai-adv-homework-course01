<div id="app">
  <!-- Hero -->
  <section class="relative w-full h-[600px] md:h-[680px] overflow-hidden border-b border-hairline">
    <img
      src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=1600&q=80"
      alt="花藝"
      class="absolute inset-0 w-full h-full object-cover opacity-45"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/50 via-ink/25 to-ink"></div>
    <div class="relative max-w-[1440px] mx-auto h-full px-6 md:px-14">
      <div class="absolute top-10 left-6 md:left-14 flex items-center gap-4 cap text-[12px] text-cream">
        <span>EST. 2026</span><span class="text-ash">/</span><span>TAIPEI 台北</span>
      </div>
      <div class="absolute bottom-16 md:bottom-24 left-6 md:left-14 max-w-3xl">
        <p class="eyebrow mb-5">— SEASONAL FLORAL ATELIER</p>
        <h1 class="font-display font-light text-cream text-6xl md:text-8xl tracking-[0.08em] leading-none">花漾生活</h1>
        <p class="font-serif italic text-mist text-lg md:text-xl mt-6 max-w-xl leading-relaxed">
          侘寂之美，敬每一束轉瞬即逝的綻放 — where every bloom honors a fleeting moment.
        </p>
        <a href="#products" class="btn-primary mt-9 text-sm">立即選購</a>
      </div>
    </div>
  </section>

  <!-- Season Intro -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-14 py-24 md:py-32 flex flex-col md:flex-row gap-12 md:gap-24">
    <div class="md:w-60 shrink-0">
      <p class="eyebrow">01 — 當季</p>
      <p class="cap text-[11px] text-ash leading-loose mt-4">OUR PHILOSOPHY<br>WABI-SABI FLORISTRY</p>
    </div>
    <div class="flex-1">
      <h2 class="font-display text-3xl md:text-[2.6rem] leading-[1.45] text-cream">
        花，是時間的容器。<br>我們珍視殘缺與凋零的美，<br>讓每一束花，都映照一期一會的當下。
      </h2>
      <p class="text-mist leading-loose mt-7 max-w-2xl">
        取材自當令花材，依循侘寂的質樸與留白，每一束作品皆為手作孤品。我們相信不完美才是自然，凋謝亦是綻放的一部分。
      </p>
    </div>
  </section>

  <!-- Featured -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-14 pb-24 md:pb-32">
    <div class="flex items-end justify-between border-b border-hairline pb-6 mb-14">
      <div>
        <p class="eyebrow mb-3">02 — 精選</p>
        <h2 class="font-display text-3xl md:text-4xl text-cream">本季精選花藝</h2>
      </div>
      <a href="#products" class="cap text-[11px] text-mist hover:text-cream transition-colors">VIEW ALL →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <div
        v-for="(product, idx) in products.slice(0, 3)"
        :key="product.id"
        @click="goToProduct(product.id)"
        :class="['group cursor-pointer', idx === 1 ? 'md:translate-y-12' : '']"
      >
        <div class="overflow-hidden bg-raised aspect-[3/4]">
          <img
            :src="product.image_url || featuredImages[idx % 4]"
            :alt="product.name"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
        </div>
        <h3 class="font-display text-xl text-cream mt-5">{{ product.name }}</h3>
        <div class="flex items-center justify-between border-t border-hairline mt-3 pt-3">
          <p class="font-serif text-lg text-kaki">NT$ {{ product.price.toLocaleString() }}</p>
          <span class="cap text-[11px] text-mist group-hover:text-cream transition-colors">ADD +</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-14 py-20 md:py-28">
    <div class="flex flex-col items-center gap-3 mb-16">
      <span class="block w-11 h-11 rounded-full border-[3px] border-kaki"></span>
      <span class="font-display text-mist tracking-[0.6em] text-sm pl-[0.6em]">侘 寂</span>
    </div>
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <div class="md:w-1/2 w-full">
        <img
          src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=900&q=80"
          alt="花藝師"
          class="w-full h-[460px] md:h-[600px] object-cover"
        />
      </div>
      <div class="md:w-1/2">
        <p class="eyebrow mb-5">03 — 我們的信念</p>
        <h2 class="font-display text-3xl md:text-4xl leading-snug text-cream">專心，做好一束花的感動</h2>
        <p class="text-mist leading-loose mt-7">
          從產地到花器，每一道工序都由花藝師親手完成。我們不追求完美無瑕，而是讓花材自然的姿態說話 — 枝的彎曲、葉的殘缺、色的深淺，都是時間留下的痕跡。
        </p>
        <p class="font-serif italic text-xl text-cream mt-8">「每一束花，都是一期一會的相遇。」</p>
      </div>
    </div>
  </section>

  <!-- All Products -->
  <section id="products" class="max-w-[1440px] mx-auto px-6 md:px-14 pb-24 md:pb-32 scroll-mt-24">
    <div class="flex items-end justify-between border-b border-hairline pb-6 mb-14">
      <div>
        <p class="eyebrow mb-3">04 — 全系列</p>
        <h2 class="font-display text-3xl md:text-4xl text-cream">探索所有花藝</h2>
      </div>
      <span class="cap text-[11px] text-ash">{{ String(pagination.total).padStart(2, '0') }} ARRANGEMENTS</span>
    </div>

    <div v-if="loading" class="flex justify-center py-20">
      <div class="w-8 h-8 border-2 border-kaki border-t-transparent rounded-full animate-spin"></div>
    </div>

    <template v-else>
      <div v-if="products.length === 0" class="text-center py-20">
        <p class="text-mist">目前沒有商品</p>
        <p class="text-ash text-sm mt-1">請稍後再來看看</p>
      </div>

      <div v-else class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
        <div
          v-for="product in products"
          :key="product.id"
          @click="goToProduct(product.id)"
          class="group cursor-pointer"
        >
          <div class="overflow-hidden bg-raised aspect-square">
            <img
              :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=600&q=80'"
              :alt="product.name"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <h3 class="font-display text-lg text-cream mt-4">{{ product.name }}</h3>
          <div class="flex items-center justify-between border-t border-hairline mt-3 pt-3">
            <p class="font-serif text-base text-kaki">NT$ {{ product.price.toLocaleString() }}</p>
            <button
              @click.stop="addToCart(product)"
              :disabled="product._adding || product.stock <= 0"
              class="cap text-[11px] text-mist hover:text-kaki transition-colors disabled:text-ash disabled:cursor-not-allowed"
            >
              {{ product.stock <= 0 ? 'SOLD OUT' : 'ADD +' }}
            </button>
          </div>
        </div>
      </div>

      <!-- Pagination -->
      <div v-if="pagination.totalPages > 1" class="flex justify-center gap-2 mt-16">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadProducts(p)"
          class="w-10 h-10 cap text-[12px] border transition-colors"
          :class="p === pagination.page ? 'border-kaki text-kaki' : 'border-hairline text-mist hover:text-cream hover:border-mist'"
        >
          {{ p }}
        </button>
      </div>
    </template>
  </section>

  <!-- Testimonials (washi paper) -->
  <section class="bg-paper text-sumi">
    <div class="max-w-[1440px] mx-auto px-6 md:px-14 py-24 md:py-28">
      <p class="eyebrow mb-4">05 — 顧客之聲</p>
      <h2 class="font-display text-3xl md:text-4xl mb-16">花束好評分享</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16">
        <div v-for="t in testimonials" :key="t.who">
          <div class="text-kaki tracking-[0.3em] mb-5">★★★★★</div>
          <p class="font-serif text-xl leading-relaxed">{{ t.text }}</p>
          <p class="cap text-[12px] text-[#6B655B] mt-5">{{ t.who }}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-14 py-24 md:py-28">
    <div class="grid grid-cols-1 md:grid-cols-3">
      <div
        v-for="(s, i) in services"
        :key="s.title"
        :class="['py-4 md:py-2', i === 0 ? 'md:pr-12' : 'md:px-12 md:border-l md:border-hairline']"
      >
        <p class="eyebrow mb-5">0{{ i + 1 }}</p>
        <h3 class="font-display text-2xl text-cream mb-3">{{ s.title }}</h3>
        <p class="text-mist leading-loose">{{ s.desc }}</p>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-raised border-t border-hairline">
    <div class="max-w-[1440px] mx-auto px-6 md:px-14 py-28 md:py-32 flex flex-col items-center text-center">
      <p class="eyebrow mb-6">— 一期一會</p>
      <h2 class="font-display font-light text-4xl md:text-5xl leading-snug text-cream max-w-3xl">預約屬於你的當季花束</h2>
      <a href="#products" class="btn-primary mt-10 text-sm">開始選購</a>
    </div>
  </section>
</div>
